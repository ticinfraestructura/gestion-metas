// Prisma Schema — SQLite — Gestión de Metas
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Usuario {
  id             Int      @id @default(autoincrement())
  nombre         String
  email          String   @unique
  password       String
  rol            String   @default("USUARIO")
  estado         String   @default("ACTIVO")
  telefono       String?
  fechaCreacion  DateTime @default(now()) @map("fecha_creacion")

  metas_creadas  Meta[]   @relation("UsuarioMetas")
  avances        Avance[] @relation("UsuarioAvances")

  @@index([email])
  @@map("usuarios")
}

model Meta {
  id             Int       @id @default(autoincrement())
  codigo         String?   @unique
  nombre         String
  descripcion    String?
  estado         String    @default("PENDIENTE")
  fecha_limite   String?
  unidades       Float?
  fecha_creacion DateTime  @default(now())
  creador_id     Int

  creador  Usuario   @relation("UsuarioMetas", fields: [creador_id], references: [id])
  avances  Avance[]
  alcances Alcance[]

  @@index([estado])
  @@map("metas")
}

model Contratista {
  id                  Int      @id @default(autoincrement())
  codigo              String?  @unique
  nombre              String
  identificacion      String   @unique
  contacto            String
  telefono            String?
  estado              String   @default("activo")
  fecha_creacion      DateTime @default(now())
  fecha_actualizacion DateTime @updatedAt

  avances  Avance[]
  alcances Alcance[]

  @@map("contratistas")
}

model Alcance {
  id                  Int      @id @default(autoincrement())
  contratistaId       Int
  metaId              Int
  descripcion         String
  fecha_inicio        String
  fecha_fin           String
  periodicidad        String   @default("MENSUAL")
  porcentaje_asignado Float    @default(100)
  fecha_creacion      DateTime @default(now())

  contratista Contratista @relation(fields: [contratistaId], references: [id], onDelete: Cascade)
  meta        Meta        @relation(fields: [metaId], references: [id], onDelete: Cascade)
  avances     Avance[]

  @@index([contratistaId])
  @@index([metaId])
  @@map("alcances")
}

model Avance {
  id                 Int      @id @default(autoincrement())
  numavance          Int      @default(1)
  descripcion        String
  fecha_presentacion String
  porcentaje_avance  Float    @default(0)
  aporte_meta        Float?
  reg_imagen         String?
  metaId             Int
  contratistaId      Int
  alcanceId          Int?
  reportado_por_id   Int
  fecha_creacion     DateTime @default(now())

  meta         Meta        @relation(fields: [metaId], references: [id], onDelete: Cascade)
  contratista  Contratista @relation(fields: [contratistaId], references: [id])
  alcance      Alcance?    @relation(fields: [alcanceId], references: [id], onDelete: SetNull)
  reportadoPor Usuario     @relation("UsuarioAvances", fields: [reportado_por_id], references: [id])

  @@index([metaId])
  @@index([contratistaId])
  @@map("avances")
}
