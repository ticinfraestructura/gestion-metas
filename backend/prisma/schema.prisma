// Prisma Schema — MySQL — Gestión de Metas
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id             Int      @id @default(autoincrement())
  nombre         String   @db.VarChar(200)
  email          String   @unique @db.VarChar(200)
  password       String   @db.VarChar(255)
  rol            String   @default("USUARIO") @db.VarChar(20)
  estado         String   @default("ACTIVO") @db.VarChar(20)
  telefono       String?  @db.VarChar(50)
  fechaCreacion  DateTime @default(now()) @map("fecha_creacion")

  metas_creadas  Meta[]   @relation("UsuarioMetas")
  avances        Avance[] @relation("UsuarioAvances")

  @@index([email])
  @@map("usuarios")
}

model Meta {
  id             Int       @id @default(autoincrement())
  codigo         String?   @unique @db.VarChar(30)
  nombre         String    @db.VarChar(300)
  descripcion    String?   @db.Text
  estado         String    @default("PENDIENTE") @db.VarChar(30)
  fecha_limite   String?   @db.VarChar(20)
  fecha_creacion DateTime  @default(now())
  creador_id     Int

  creador  Usuario   @relation("UsuarioMetas", fields: [creador_id], references: [id])
  avances  Avance[]
  alcances Alcance[]

  @@index([estado])
  @@map("metas")
}

model Contratista {
  id                  Int      @id @default(autoincrement())
  codigo              String?  @unique @db.VarChar(30)
  nombre              String   @db.VarChar(300)
  identificacion      String   @unique @db.VarChar(50)
  contacto            String   @db.VarChar(200)
  telefono            String?  @db.VarChar(50)
  estado              String   @default("activo") @db.VarChar(20)
  fecha_creacion      DateTime @default(now())
  fecha_actualizacion DateTime @updatedAt

  avances  Avance[]
  alcances Alcance[]

  @@map("contratistas")
}

model Alcance {
  id                  Int      @id @default(autoincrement())
  contratistaId       Int
  metaId              Int
  descripcion         String   @db.Text
  fecha_inicio        String   @db.VarChar(20)
  fecha_fin           String   @db.VarChar(20)
  periodicidad        String   @default("MENSUAL") @db.VarChar(20)
  porcentaje_asignado Float    @default(100)
  fecha_creacion      DateTime @default(now())

  contratista Contratista @relation(fields: [contratistaId], references: [id], onDelete: Cascade)
  meta        Meta        @relation(fields: [metaId], references: [id], onDelete: Cascade)
  avances     Avance[]

  @@index([contratistaId])
  @@index([metaId])
  @@map("alcances")
}

model Avance {
  id                 Int      @id @default(autoincrement())
  numavance          Int      @default(1)
  descripcion        String   @db.Text
  fecha_presentacion String   @db.VarChar(30)
  porcentaje_avance  Float    @default(0)
  reg_imagen         String?  @db.VarChar(500)
  metaId             Int
  contratistaId      Int
  alcanceId          Int?
  reportado_por_id   Int
  fecha_creacion     DateTime @default(now())

  meta         Meta        @relation(fields: [metaId], references: [id], onDelete: Cascade)
  contratista  Contratista @relation(fields: [contratistaId], references: [id])
  alcance      Alcance?    @relation(fields: [alcanceId], references: [id], onDelete: SetNull)
  reportadoPor Usuario     @relation("UsuarioAvances", fields: [reportado_por_id], references: [id])

  @@index([metaId])
  @@index([contratistaId])
  @@map("avances")
}
